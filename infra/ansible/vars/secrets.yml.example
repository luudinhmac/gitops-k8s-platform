# TEMPLATE FILE - Hướng dẫn thiết lập Secrets
# 1. Copy file này thành: vars/secrets.yml
# 2. Điền các giá trị thực tế vào
# 3. Chạy lệnh mã hóa: ansible-vault encrypt vars/secrets.yml

# Token cho GitLab Runner Staging
RUNNER_TOKEN_STAGING: "your-staging-token-here"

# Token cho GitLab Runner Production
GITLAB_RUNNER_TOKEN_PROD: "your-production-token-here"

# Cấu hình Database (Nếu muốn ghi đè)
# DB_PASSWORD: "your-secure-password"
